{
  "project": {
    "title": "PCB Testing Automation System",
    "organization": "Forbes Marshall",
    "type": "Industry Project",
    "date": "March 2026",
    "tagline": "Automated multi-stage PCB quality assurance platform with role-based access control, serial hardware integration, and comprehensive test traceability."
  },

  "overview": {
    "description": "The PCB Testing Automation System is a desktop application built for Forbes Marshall to automate and standardize PCB (Printed Circuit Board) testing workflows. It replaces manual testing processes with a centralized, configurable, and traceable system backed by a MySQL database with 9 normalized tables and 40+ API methods.",
    "database_tables": 9,
    "api_methods": "40+",
    "database_type": "MySQL"
  },

  "key_highlights": [
    "4-Phase Development — Core Testing → Test Management → Advanced Multi-Stage Testing → Hardware Integration",
    "Role-Based Access Control — Admin, Manager, Tester with hierarchical permissions",
    "MySQL Database — 9 tables, 10+ indexes, foreign key constraints, audit logging",
    "Serial Communication — Real-time PCB data capture via COM port (PySerial)",
    "Barcode Scanner — USB barcode scanner support for automatic PCB identification",
    "Modern GUI — CustomTkinter-based dark-themed interface"
  ],

  "technology_stack": [
    { "layer": "Language", "technology": "Python 3.8+" },
    { "layer": "GUI Framework", "technology": "CustomTkinter 5.2.1" },
    { "layer": "Database", "technology": "MySQL 8.0" },
    { "layer": "DB Connector", "technology": "mysql-connector-python 8.2+" },
    { "layer": "Image Handling", "technology": "Pillow 10.2+" },
    { "layer": "Serial Comm", "technology": "PySerial 3.5+" },
    { "layer": "Password Hashing", "technology": "bcrypt 4.1+" },
    { "layer": "Packaging", "technology": "PyInstaller" }
  ],

  "features": {
    "phase_1_core_testing": {
      "title": "Phase 1 — Core Testing",
      "items": [
        "User authentication with bcrypt password hashing",
        "Role-based login with dynamic dashboard",
        "Start Test with manual parameter entry",
        "Pass/Fail validation for Voltage, Current, and Resistance",
        "Results stored in MySQL with timestamps"
      ]
    },
    "phase_2_test_management": {
      "title": "Phase 2 — Test Management",
      "items": [
        "Results History with filtering by date, status, user, and PCB serial number",
        "CSV export of test results",
        "Test Case Editor — create and manage test profiles with custom thresholds",
        "Pass rate statistics and tracking",
        "Role-based result visibility"
      ]
    },
    "phase_3_advanced_testing": {
      "title": "Phase 3 — Advanced Multi-Stage Testing",
      "items": [
        "Stage Builder — define ordered multi-stage test sequences",
        "Each stage has independent voltage/current/resistance thresholds and duration",
        "Advanced Test Runner — sequential stage execution with real-time progress",
        "Per-stage failure reporting with detailed failure reasons",
        "Custom workflows for different PCB types"
      ]
    },
    "phase_4_hardware_integration": {
      "title": "Phase 4 — Hardware Integration",
      "items": [
        "Serial Communication via COM port (configurable baud rate, data bits, stop bits, parity, timeout)",
        "Expected PCB data format: V:5.0,C:0.5,R:100.0",
        "Automatic vs Manual test mode switching",
        "USB Barcode Scanner support (keyboard emulation mode)",
        "Jig Diagram Viewer — upload and view test fixture reference images (PNG, JPG, GIF, BMP)",
        "Admin-controlled communication settings"
      ]
    }
  },

  "installation": {
    "prerequisites": [
      "Python 3.8 or higher",
      "MySQL Server 8.0+ (running)"
    ],
    "steps": [
      "pip install -r requirements.txt",
      "Configure MySQL credentials in config/config.py (Edit DB_HOST, DB_USER, DB_PASSWORD, DB_PORT as needed)",
      "python init_mysql.py (Initialize the database — creates tables + default users)",
      "python health_checker.py (Verify installation)",
      "python main.py (Run the application)"
    ],
    "default_credentials": [
      { "role": "Admin", "username": "admin", "password": "admin123" },
      { "role": "Manager", "username": "manager", "password": "manager123" },
      { "role": "Tester", "username": "tester", "password": "tester123" }
    ]
  },

  "database_schema": {
    "database_name": "pcb_testing",
    "total_tables": 9,
    "tables": {
      "users": {
        "purpose": "User accounts with hashed passwords",
        "key_relationships": "Referenced by most tables",
        "columns": [
          { "name": "id", "type": "INT (PK)", "constraints": "AUTO_INCREMENT" },
          { "name": "username", "type": "VARCHAR(255)", "constraints": "UNIQUE, NOT NULL" },
          { "name": "password_hash", "type": "VARCHAR(255)", "constraints": "NOT NULL (bcrypt)" },
          { "name": "role", "type": "ENUM", "constraints": "'Admin', 'Manager', 'Tester'" },
          { "name": "email", "type": "VARCHAR(255)", "constraints": "" },
          { "name": "created_at", "type": "TIMESTAMP", "constraints": "DEFAULT CURRENT_TIMESTAMP" },
          { "name": "is_active", "type": "BOOLEAN", "constraints": "DEFAULT 1" }
        ]
      },
      "test_cases": {
        "purpose": "Test profiles with min/max thresholds",
        "key_relationships": "FK → users",
        "columns": [
          { "name": "id", "type": "INT (PK)", "constraints": "AUTO_INCREMENT" },
          { "name": "name", "type": "VARCHAR(255)", "constraints": "NOT NULL" },
          { "name": "description", "type": "TEXT", "constraints": "" },
          { "name": "voltage_min", "type": "DECIMAL(10,2)", "constraints": "NOT NULL" },
          { "name": "voltage_max", "type": "DECIMAL(10,2)", "constraints": "NOT NULL" },
          { "name": "current_min", "type": "DECIMAL(10,2)", "constraints": "NOT NULL" },
          { "name": "current_max", "type": "DECIMAL(10,2)", "constraints": "NOT NULL" },
          { "name": "resistance_min", "type": "DECIMAL(10,2)", "constraints": "NOT NULL" },
          { "name": "resistance_max", "type": "DECIMAL(10,2)", "constraints": "NOT NULL" },
          { "name": "created_by", "type": "INT (FK)", "constraints": "→ users(id)" },
          { "name": "created_at", "type": "TIMESTAMP", "constraints": "DEFAULT CURRENT_TIMESTAMP" },
          { "name": "updated_at", "type": "TIMESTAMP", "constraints": "ON UPDATE CURRENT_TIMESTAMP" }
        ]
      },
      "test_stages": {
        "purpose": "Individual stages in multi-stage tests",
        "key_relationships": "FK → test_cases",
        "columns": [
          { "name": "id", "type": "INT (PK)", "constraints": "AUTO_INCREMENT" },
          { "name": "test_case_id", "type": "INT (FK)", "constraints": "→ test_cases(id) ON DELETE CASCADE" },
          { "name": "stage_number", "type": "INT", "constraints": "UNIQUE with test_case_id" },
          { "name": "stage_name", "type": "VARCHAR(100)", "constraints": "NOT NULL" },
          { "name": "description", "type": "TEXT", "constraints": "" },
          { "name": "voltage_min", "type": "REAL", "constraints": "" },
          { "name": "voltage_max", "type": "REAL", "constraints": "" },
          { "name": "current_min", "type": "REAL", "constraints": "" },
          { "name": "current_max", "type": "REAL", "constraints": "" },
          { "name": "resistance_min", "type": "REAL", "constraints": "" },
          { "name": "resistance_max", "type": "REAL", "constraints": "" },
          { "name": "duration_seconds", "type": "INT", "constraints": "" },
          { "name": "created_at", "type": "TIMESTAMP", "constraints": "DEFAULT CURRENT_TIMESTAMP" },
          { "name": "updated_at", "type": "TIMESTAMP", "constraints": "DEFAULT CURRENT_TIMESTAMP" }
        ]
      },
      "test_results": {
        "purpose": "Overall test execution records",
        "key_relationships": "FK → test_cases, users",
        "columns": [
          { "name": "id", "type": "INT (PK)", "constraints": "AUTO_INCREMENT" },
          { "name": "test_case_id", "type": "INT (FK)", "constraints": "→ test_cases(id)" },
          { "name": "user_id", "type": "INT (FK)", "constraints": "→ users(id)" },
          { "name": "pcb_serial_number", "type": "VARCHAR(100)", "constraints": "" },
          { "name": "status", "type": "VARCHAR(20)", "constraints": "'Pass', 'Fail', 'In Progress'" },
          { "name": "overall_pass", "type": "BOOLEAN", "constraints": "" },
          { "name": "start_time", "type": "TIMESTAMP", "constraints": "DEFAULT CURRENT_TIMESTAMP" },
          { "name": "end_time", "type": "TIMESTAMP", "constraints": "" },
          { "name": "notes", "type": "TEXT", "constraints": "" }
        ]
      },
      "test_stage_results": {
        "purpose": "Per-stage measured values and outcomes",
        "key_relationships": "FK → test_results, test_stages",
        "columns": [
          { "name": "id", "type": "INT (PK)", "constraints": "AUTO_INCREMENT" },
          { "name": "test_result_id", "type": "INT (FK)", "constraints": "→ test_results(id) ON DELETE CASCADE" },
          { "name": "stage_id", "type": "INT (FK)", "constraints": "→ test_stages(id)" },
          { "name": "voltage_measured", "type": "REAL", "constraints": "" },
          { "name": "current_measured", "type": "REAL", "constraints": "" },
          { "name": "resistance_measured", "type": "REAL", "constraints": "" },
          { "name": "status", "type": "VARCHAR(20)", "constraints": "'Pass', 'Fail', 'Not Run'" },
          { "name": "failure_reason", "type": "TEXT", "constraints": "" },
          { "name": "start_time", "type": "TIMESTAMP", "constraints": "" },
          { "name": "end_time", "type": "TIMESTAMP", "constraints": "" }
        ]
      },
      "communication_config": {
        "purpose": "Serial port configuration profiles",
        "key_relationships": "FK → users",
        "columns": [
          { "name": "id", "type": "INT (PK)", "constraints": "AUTO_INCREMENT" },
          { "name": "config_name", "type": "VARCHAR(100)", "constraints": "NOT NULL" },
          { "name": "com_port", "type": "VARCHAR(10)", "constraints": "" },
          { "name": "baud_rate", "type": "INT", "constraints": "DEFAULT 9600" },
          { "name": "data_bits", "type": "INT", "constraints": "DEFAULT 8" },
          { "name": "stop_bits", "type": "INT", "constraints": "DEFAULT 1" },
          { "name": "parity", "type": "VARCHAR(10)", "constraints": "DEFAULT 'None'" },
          { "name": "timeout_seconds", "type": "INT", "constraints": "DEFAULT 5" },
          { "name": "created_by", "type": "INT (FK)", "constraints": "→ users(id)" },
          { "name": "created_at", "type": "TIMESTAMP", "constraints": "DEFAULT CURRENT_TIMESTAMP" },
          { "name": "updated_at", "type": "TIMESTAMP", "constraints": "DEFAULT CURRENT_TIMESTAMP" }
        ]
      },
      "jig_diagrams": {
        "purpose": "Test jig reference images",
        "key_relationships": "FK → test_cases, users",
        "columns": [
          { "name": "id", "type": "INT (PK)", "constraints": "AUTO_INCREMENT" },
          { "name": "test_case_id", "type": "INT (FK)", "constraints": "→ test_cases(id) ON DELETE SET NULL" },
          { "name": "diagram_name", "type": "VARCHAR(100)", "constraints": "NOT NULL" },
          { "name": "file_path", "type": "VARCHAR(255)", "constraints": "NOT NULL" },
          { "name": "description", "type": "TEXT", "constraints": "" },
          { "name": "uploaded_by", "type": "INT (FK)", "constraints": "→ users(id)" },
          { "name": "uploaded_at", "type": "TIMESTAMP", "constraints": "DEFAULT CURRENT_TIMESTAMP" }
        ]
      },
      "test_statistics": {
        "purpose": "Aggregated pass/fail stats per test case",
        "key_relationships": "FK → test_cases (UNIQUE)",
        "columns": [
          { "name": "id", "type": "INT (PK)", "constraints": "AUTO_INCREMENT" },
          { "name": "test_case_id", "type": "INT (FK)", "constraints": "→ test_cases(id), UNIQUE" },
          { "name": "total_tests", "type": "INT", "constraints": "DEFAULT 0" },
          { "name": "passed_tests", "type": "INT", "constraints": "DEFAULT 0" },
          { "name": "failed_tests", "type": "INT", "constraints": "DEFAULT 0" },
          { "name": "pass_rate", "type": "REAL", "constraints": "DEFAULT 0.0" },
          { "name": "last_updated", "type": "TIMESTAMP", "constraints": "DEFAULT CURRENT_TIMESTAMP" }
        ]
      },
      "audit_log": {
        "purpose": "Complete activity audit trail",
        "key_relationships": "FK → users",
        "columns": [
          { "name": "id", "type": "INT (PK)", "constraints": "AUTO_INCREMENT" },
          { "name": "user_id", "type": "INT (FK)", "constraints": "→ users(id)" },
          { "name": "action", "type": "VARCHAR(100)", "constraints": "NOT NULL" },
          { "name": "entity_type", "type": "VARCHAR(50)", "constraints": "" },
          { "name": "entity_id", "type": "INT", "constraints": "" },
          { "name": "old_values", "type": "TEXT", "constraints": "" },
          { "name": "new_values", "type": "TEXT", "constraints": "" },
          { "name": "timestamp", "type": "TIMESTAMP", "constraints": "DEFAULT CURRENT_TIMESTAMP" }
        ]
      }
    },
    "entity_relationships": [
      { "from": "users", "to": "test_cases", "cardinality": "1:N" },
      { "from": "users", "to": "test_results", "cardinality": "1:N" },
      { "from": "users", "to": "communication_config", "cardinality": "1:N" },
      { "from": "users", "to": "audit_log", "cardinality": "1:N" },
      { "from": "users", "to": "jig_diagrams", "cardinality": "1:N" },
      { "from": "test_cases", "to": "test_stages", "cardinality": "1:N" },
      { "from": "test_cases", "to": "test_results", "cardinality": "1:N" },
      { "from": "test_cases", "to": "jig_diagrams", "cardinality": "1:N" },
      { "from": "test_cases", "to": "test_statistics", "cardinality": "1:1" },
      { "from": "test_results", "to": "test_stage_results", "cardinality": "1:N" },
      { "from": "test_stages", "to": "test_stage_results", "cardinality": "1:N" }
    ],
    "performance_indexes": [
      { "name": "idx_users_username", "table": "users", "column": "username" },
      { "name": "idx_users_role", "table": "users", "column": "role" },
      { "name": "idx_test_results_user_id", "table": "test_results", "column": "user_id" },
      { "name": "idx_test_results_test_case_id", "table": "test_results", "column": "test_case_id" },
      { "name": "idx_test_results_start_time", "table": "test_results", "column": "start_time" },
      { "name": "idx_test_stage_results_test_result_id", "table": "test_stage_results", "column": "test_result_id" },
      { "name": "idx_test_stages_test_case_id", "table": "test_stages", "column": "test_case_id" },
      { "name": "idx_jig_diagrams_test_case_id", "table": "jig_diagrams", "column": "test_case_id" },
      { "name": "idx_audit_log_user_id", "table": "audit_log", "column": "user_id" },
      { "name": "idx_audit_log_timestamp", "table": "audit_log", "column": "timestamp" }
    ]
  },

  "user_roles": {
    "hierarchy": "Admin (Level 3) > Manager (Level 2) > Tester (Level 1)",
    "roles": [
      { "role": "Admin", "level": 3 },
      { "role": "Manager", "level": 2 },
      { "role": "Tester", "level": 1 }
    ],
    "permissions": {
      "login_and_dashboard": { "Admin": true, "Manager": true, "Tester": true },
      "run_tests": { "Admin": true, "Manager": true, "Tester": true },
      "view_test_results": { "Admin": true, "Manager": true, "Tester": true },
      "view_jig_diagrams": { "Admin": true, "Manager": true, "Tester": true },
      "create_edit_test_cases": { "Admin": true, "Manager": true, "Tester": false },
      "build_multi_stage_tests": { "Admin": true, "Manager": true, "Tester": false },
      "export_data": { "Admin": true, "Manager": true, "Tester": false },
      "upload_jig_diagrams": { "Admin": true, "Manager": false, "Tester": false },
      "configure_com_ports": { "Admin": true, "Manager": false, "Tester": false },
      "user_management": { "Admin": true, "Manager": false, "Tester": false }
    }
  },

  "test_parameter_ranges": {
    "note": "Custom thresholds can be defined per test case and per stage via the Test Case Editor and Stage Builder.",
    "defaults": [
      { "parameter": "Voltage", "minimum": 4.5, "maximum": 5.5, "unit": "V" },
      { "parameter": "Current", "minimum": 0.1, "maximum": 1.0, "unit": "A" },
      { "parameter": "Resistance", "minimum": 90, "maximum": 110, "unit": "Ω" }
    ]
  },

  "project_structure": {
