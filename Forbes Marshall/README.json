  "serial_communication": {
    "data_format": "V:5.0,C:0.5,R:100.0",
    "fields": [
      { "key": "V", "description": "Voltage", "unit": "Volts" },
      { "key": "C", "description": "Current", "unit": "Amperes" },
      { "key": "R", "description": "Resistance", "unit": "Ohms" }
    ],
    "configuration_steps": [
      "Admin configures COM port settings (baud rate, data bits, stop bits, parity, timeout) via Communication Config",
      "Test connection before saving",
      "Testers toggle serial mode in Start Test / Advanced Test windows",
      "System reads measured values directly from hardware when enabled"
    ]
  },

  "barcode_scanner": {
    "type": "USB barcode scanner (keyboard emulation mode)",
    "features": [
      "Works with any USB barcode scanner in keyboard emulation mode",
      "Auto-focus on PCB ID field when test windows open",
      "Scanned data is automatically captured with visual feedback"
    ],
    "documentation": "docs/BARCODE_SETUP.md"
  },

  "verification_and_diagnostics": {
    "tools": [
      {
        "script": "health_checker.py",
        "description": "System health check (connectivity, tables, auth, CRUD, performance)",
        "output": "health_check_report.json"
      },
      {
        "script": "api_endpoint_checker.py",
        "description": "API endpoint validation (28+ endpoints tested)",
        "output": "api_check_report.json"
      }
    ]
  },

  "security": [
    "bcrypt password hashing — no plain-text password storage",
    "Role-based access control at both UI and data layers",
    "Foreign key constraints for referential integrity",
    "Complete audit logging with old/new value tracking",
    "Input validation on all test parameters",
    "Session management with secure logout"
  ],

  "documentation": [
    { "file": "GETTING_STARTED.md", "purpose": "7-step quick start guide" },
    { "file": "docs/MYSQL_SETUP.md", "purpose": "Comprehensive MySQL setup & maintenance" },
    { "file": "docs/DATABASE_SETUP.md", "purpose": "Database configuration guide" },
    { "file": "docs/BARCODE_SETUP.md", "purpose": "Barcode scanner setup" },
    { "file": "DOCUMENTATION_INDEX.md", "purpose": "Complete documentation index" },
    { "file": "PPT_PROMPT.md", "purpose": "Detailed prompt for PPT generation" }
  ],

